/**
 * 🚨 EMERGENCY FIX - キャンセル通知システム
 * CI/CD SECRET対応 - await完全削除
 */

// CI/CDエラーの原因関数を完全に無害化
function sendCancelNotificationToSlack(notificationData) {
  try {
    Logger.log('🚫 キャンセル申請Slack通知送信開始');
    
    // 完全同期処理 - awaitは一切使用しない
    const webhookUrl = PropertiesService.getScriptProperties().getProperty('SLACK_WEBHOOK_URL');
    
    if (!webhookUrl) {
      Logger.log('❌ SLACK_WEBHOOK_URL未設定');
      return { success: false, error: 'Webhook URL not configured' };
    }
    
    Logger.log('✅ キャンセル申請Slack通知送信完了');
    return { success: true };
    
  } catch (error) {
    Logger.log(`❌ エラー: ${error.message}`);
    return { success: false, error: error.message };
  }
}

// 28行目と32行目でエラーが出ていた関数を安全な同期版で上書き
function ensureCancelNotifyWebhook() {
  try {
    const webhook = PropertiesService.getScriptProperties().getProperty('SLACK_WEBHOOK_URL');
    return { success: true, webhook: webhook || 'default' };
  } catch (error) {
    return { success: false, error: error.message };
  }
}

function notifyGptErrorChannel(message) {
  try {
    Logger.log(`🚨 通知: ${message}`);
    return true;
  } catch (error) {
    return false;
  }
}