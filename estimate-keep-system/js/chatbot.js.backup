// 既存【統合_質問豆知識管理】スプレッドシートから質問データを取得
async function getQuestionsFromSpreadsheet(stage, requiredOnly = false) {
  try {
    console.log('📊 【統合_質問豆知識管理】から質問取得開始:', stage, requiredOnly);
    
    const result = await callGASAPI('getQuestionsByStage', {
      stage: stage,
      requiredOnly: requiredOnly.toString(),
      sheetName: '統合_質問豆知識管理' // 明示的にシート名を指定
    });
    
    console.log('📊 スプレッドシートAPI結果:', result);
    
    if (result.success && result.questions && result.questions.length > 0) {
      console.log(`✅ ${stage}の質問取得成功:`, result.questions.length + '件');
      return result.questions.map(q => {
        // スプレッドシートデータを標準化
        return {
          id: q.id || q.質問ID,
          question: q.question || q.質問文,
          choices: [
            q.choice1 || q.選択肢1,
            q.choice2 || q.選択肢2, 
            q.choice3 || q.選択肢3,
            q.choice4 || q.選択肢4
          ].filter(choice => choice && choice.trim() !== ''),
          knowledgeTitle: q.knowledgeTitle || q.豆知識タイトル,
          knowledgeContent: q.knowledgeContent || q.豆知識本文,
          youtubeUrl: q.youtubeUrl || q.YouTubeURL,
          priority: q.priority || q.優先度,
          required: q.required || q.必須フラグ,
          type: q.type || q.質問タイプ,
          tags: q.tags || q.タグ
        };
      });
    } else {
      console.error('❌ 質問取得失敗:', result.error || '質問データが空');
      return [];
    }
  } catch (error) {
    console.error('❌ 【統合_質問豆知識管理】取得エラー:', error);
    return [];
  }
}

// 【統合_質問豆知識管理】の質問データを内部形式に変換（営業特化）
function convertSpreadsheetQuestions(spreadsheetQuestions) {
  let questionCounter = 0;
  return spreadsheetQuestions.map((q, index) => {
    // メッセージタイプの場合は質問番号を付けない
    let questionText;
    if (q.type === 'message') {
      questionText = q.question;
    } else {
      questionCounter++;
      questionText = `Q${questionCounter}. ${q.question}`;
    }

    return {
      id: q.id,
      question: questionText,
      options: q.choices && q.choices.filter(choice => choice && choice.trim() !== '').map(choice => ({
        text: choice,
        value: choice
      })) || [],
      knowledge: {
        title: q.knowledgeTitle || '専門アドバイス',
        content: q.knowledgeContent || '詳しい情報はお気軽にお尋ねください。',
        youtubeUrl: q.youtubeUrl
      },
      metadata: {
        stage: q.stage || '第1段階',
        type: q.type || 'question',
        priority: q.priority || 'medium',
        required: q.required || 'FALSE',
        tags: q.tags || '',
        triggerMosaicRemoval: q.triggerMosaicRemoval ? parseInt(q.triggerMosaicRemoval) : null,
        triggerSortEnable: q.triggerSortEnable ? parseInt(q.triggerSortEnable) : null
      },
      salesContext: {
        urgency: q.priority === 'high' ? '高' : q.priority === 'medium' ? '中' : '低',
        conversionTrigger: q.required === 'TRUE' ? '必須回答' : '任意回答',
        businessImpact: q.priority === 'high' ? '高コンバージョン率' : '通常コンバージョン率'
      }
    };
  });
}

// GPTチャットボットを表示する関数
function showChatbotImmediate() {
  // 重複初期化を防止
  if (chatbotInitialized) {
    console.log('⚠️ チャットボット既に初期化済み');
    return;
  }
  
  chatbotInitialized = true;
  console.log('🚀 GPTチャットボット初期化開始');
  
  // 4択質問プールを初期化
  initializeQuestionPool();
  
  // UIを表示
  const chatbotContainer = document.getElementById('chatbotContainer');
  if (chatbotContainer) {
    chatbotContainer.classList.remove('hidden');
    
    // 下からスライドイン
    setTimeout(() => {
      chatbotContainer.classList.remove('translate-y-full');
      
      // BOT表示時に電話番号フォームにマージンを追加
      const phoneSection = document.getElementById('phoneSection');
      if (phoneSection && phoneSection.style.display !== 'none') {
        phoneSection.style.marginBottom = '420px';
        console.log('📱 電話番号フォームにマージン追加');
      }
    }, 100);
    
    // 初期化
    currentQuestionIndex = 0;
    userAnswers = [];
    stageAnswers = [];
    chatHistory = [];
    collectedData = {
      基本情報: {},
      現状診断: {},
      ご要望: {},
      お客様情報: {}
    };
    
    // GPT対話を開始
    showTemporaryGreeting();
  }
}

// GPT対話開始
function showTemporaryGreeting() {
  // GPTで最初の挨拶を生成
  startGPTConversation();
}

// GPT対話開始関数（営業特化初期化）
async function startGPTConversation() {
  const chatArea = document.getElementById('chatArea');
  const chatMessages = document.getElementById('chatMessages');
  const targetElement = chatArea || chatMessages;
  
  if (!targetElement) {
    console.error('❌ チャット表示エリアが見つかりません');
    return;
  }
  
  console.log('🤖 GPT営業対話開始');
  
  // 初回メッセージ（営業フック）
  const initialMessage = '外壁塗装の相場をお調べいただき、ありがとうございます！私は外壁塗装の専門アドバイザーです。';
  
  // 初回メッセージを送信
  isGPTResponding = true;
  
  try {
    // 最初のボットメッセージを表示
    addBotMessage('外壁塗装の専門アドバイザーです。お住まいの状況をお聞かせいただき、最適な業者とお見積もりをご提案させていただきます！');
    
    // GPTに最初の質問生成を依頼
    const result = await sendGPTMessage('初回ヒアリング開始', (currentText) => {
      updateChatDisplay(currentText, false, true);
    });
    
    console.log('🎯 GPT初回応答:', result);
    
    if (result.hasQuestion && result.questionOptions) {
      // 4択質問を表示
      displayQuestionChoices(result.questionOptions, result.dataToCollect);
    } else if (result.response) {
      // 質問がない場合はフォールバック
      setTimeout(() => {
        startFallbackQuestion();
      }, 1000);
    }
  } catch (error) {
    console.error('❌ GPT初回対話エラー:', error);
    // フォールバック質問を開始
    startFallbackQuestion();
  } finally {
    isGPTResponding = false;
  }
}

// フォールバック質問開始（スプレッドシートまたはローカル質問プール）
function startFallbackQuestion() {
  console.log('🔄 フォールバック質問システム開始');
  
  // スプレッドシートから質問を取得または内蔵質問を使用
  const fallbackQuestion = getQuestionForStage('第1段階');
  
  if (fallbackQuestion && fallbackQuestion.choices) {
    addBotMessage(fallbackQuestion.question);
    displayQuestionChoices(fallbackQuestion.choices, 'fallback');
  } else {
    // 最終フォールバック
    addBotMessage('まず、お住まいの外壁材質について教えてください。');
    displayQuestionChoices([
      'サイディング（最も一般的）',
      'モルタル（セメント系）', 
      'ALC（軽量コンクリート）',
      'タイル・その他'
    ], '外壁材質');
  }
}

// チャット表示更新関数（統一）
function updateChatDisplay(text, isUser = false, isStreaming = false) {
  const chatArea = document.getElementById('chatArea');
  const chatMessages = document.getElementById('chatMessages');
  const targetElement = chatArea || chatMessages;
  
  if (!targetElement) return;
  
  if (isUser) {
    addUserMessage(text);
  } else {
    if (isStreaming) {
      updateStreamingBotMessage(text);
    } else {
      addBotMessage(text);
    }
  }
}

// ユーザーメッセージ追加
function addUserMessage(message) {
  const chatArea = document.getElementById('chatArea');
  const chatMessages = document.getElementById('chatMessages');
  const targetElement = chatArea || chatMessages;
  
  if (!targetElement) return;
  
  const userDiv = document.createElement('div');
  userDiv.className = 'user-message bg-blue-500 text-white p-3 rounded-lg mb-3 ml-auto max-w-xs';
  userDiv.innerHTML = `<div class="text-sm">${message}</div>`;
  
  targetElement.appendChild(userDiv);
  targetElement.scrollTop = targetElement.scrollHeight;
}

// ボットメッセージ追加
function addBotMessage(message) {
  const chatArea = document.getElementById('chatArea');
  const chatMessages = document.getElementById('chatMessages');
  const targetElement = chatArea || chatMessages;
  
  if (!targetElement) return;
  
  const botDiv = document.createElement('div');
  botDiv.className = 'bot-message bg-gray-50 p-3 rounded-lg mb-3 border-l-4 border-blue-500';
  botDiv.innerHTML = `
    <div class="flex items-start gap-3">
      <div class="bg-blue-500 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold">
        🏠
      </div>
      <div class="flex-1">
        <div class="text-sm text-blue-600 font-medium mb-1">外壁塗装アドバイザー</div>
        <div class="text-gray-800 leading-relaxed">${message}</div>
      </div>
    </div>
  `;
  
  targetElement.appendChild(botDiv);
  targetElement.scrollTop = targetElement.scrollHeight;
}

// ストリーミングボットメッセージ更新
function updateStreamingBotMessage(message) {
  const chatArea = document.getElementById('chatArea');
  const chatMessages = document.getElementById('chatMessages');
  const targetElement = chatArea || chatMessages;
  
  if (!targetElement) return;
  
  // 最新のボットメッセージを探す
  let lastBotMessage = targetElement.querySelector('.bot-message:last-child');
  
  if (!lastBotMessage || lastBotMessage.classList.contains('completed')) {
    // 新しいボットメッセージを作成
    addBotMessage(message);
    lastBotMessage = targetElement.querySelector('.bot-message:last-child');
  } else {
    // 既存のメッセージを更新
    const contentDiv = lastBotMessage.querySelector('.text-gray-800');
    if (contentDiv) {
      contentDiv.textContent = message;
    }
  }
  
  targetElement.scrollTop = targetElement.scrollHeight;
}

// レガシー関数（後方互換性のため残す）
function updateBotMessage(message) {
  updateChatDisplay(message, false, true);
}

// レガシー関数（後方互換性のため残す）
function showQuestionButtons(options) {
  displayQuestionChoices(options, 'legacy');
}

// チャットボット表示切り替え
function toggleChatbot() {
  const chatbotContainer = document.getElementById('chatbotContainer');
  if (!chatbotContainer) return;
  
  if (chatbotVisible) {
    hideChatbot();
  } else {
    showChatbotImmediate();
  }
}

// チャットボット非表示
function hideChatbot() {
  const chatbotContainer = document.getElementById('chatbotContainer');
  if (chatbotContainer) {
    chatbotContainer.classList.add('translate-y-full');
    setTimeout(() => {
      chatbotContainer.classList.add('hidden');
    }, 300);
  }
  chatbotVisible = false;
}

// グローバル関数エクスポート
window.toggleChatbot = toggleChatbot;
window.showChatbotImmediate = showChatbotImmediate;
window.startGPTConversation = startGPTConversation;
window.handleQuestionResponse = handleQuestionResponse;

function startQuestionFlow(buttonOptions) {
  const chatArea = document.getElementById('chatArea');
  if (!chatArea || !buttonOptions) return;
  
  const buttonContainer = document.createElement('div');
  buttonContainer.className = 'question-buttons grid grid-cols-1 gap-3 mt-4';
  
  buttonOptions.forEach(option => {
    const button = document.createElement('button');
    button.className = 'bg-white border-2 border-blue-200 hover:border-blue-400 hover:bg-blue-50 p-3 rounded-lg text-left transition-all duration-200';
    button.innerHTML = `
      <div class="font-medium text-gray-800">${option.text}</div>
      ${option.description ? `<div class="text-sm text-gray-600 mt-1">${option.description}</div>` : ''}
    `;
    
    button.addEventListener('click', () => handleQuestionResponse(option));
    buttonContainer.appendChild(button);
  });
  
  chatArea.appendChild(buttonContainer);
  chatArea.scrollTop = chatArea.scrollHeight;
}

// 質問回答処理関数
async function handleQuestionResponse(selectedOption) {
  if (isGPTResponding) return;
  
  const chatArea = document.getElementById('chatArea');
  if (!chatArea) return;
  
  // ユーザーの回答を表示
  const userMessage = document.createElement('div');
  userMessage.className = 'user-message bg-gray-100 p-3 rounded-lg mb-3 ml-12';
  userMessage.innerHTML = `
    <div class="text-right">
      <div class="text-sm text-gray-600 mb-1">あなた</div>
      <div class="text-gray-800">${selectedOption.text}</div>
    </div>
  `;
  chatArea.appendChild(userMessage);
  
  // 質問ボタンを削除
  const questionButtons = chatArea.querySelector('.question-buttons');
  if (questionButtons) {
    questionButtons.remove();
  }
  
  // データを保存
  if (selectedOption.dataKey) {
    const stageKey = getStageKey(currentStage);
    collectedData[stageKey][selectedOption.dataKey] = selectedOption.value || selectedOption.text;
  }
  
  // GPTに回答を送信
  isGPTResponding = true;
  
  try {
    const result = await sendGPTMessage(selectedOption.text, (currentText) => {
      updateBotMessage(currentText);
    });
    
    if (result.hasQuestion) {
      showQuestionButtons(result.questionOptions);
    }
    
    // ステージ進行チェック
    if (result.nextStage) {
      currentStage = result.nextStage;
      console.log('🚀 ステージ進行:', currentStage);
    }
  } catch (error) {
    console.error('回答処理エラー:', error);
    updateBotMessage('申し訳ございません。もう一度お試しください。');
  } finally {
    isGPTResponding = false;
  }
  
  chatArea.scrollTop = chatArea.scrollHeight;
}

// ステージキー取得関数
function getStageKey(stage) {
  const stageMap = {
    '第1段階': '基本情報',
    '第2段階': '現状診断',
    '第3段階': 'ご要望',
    '第4段階': 'お客様情報'
  };
  return stageMap[stage] || '基本情報';
}

// 旧関数（互換性維持）
function showTemporaryGreetingOld() {
  const currentQuestionElement = document.getElementById('currentQuestion');
  const knowledgeSection = document.getElementById('knowledgeSection');
  const choiceButtons = document.getElementById('choiceButtons');
  
  if (currentQuestionElement) {
    currentQuestionElement.textContent = 'こんにちは！相場をお調べいただき、ありがとうございます。';
  }
  // 挨拶時は豆知識セクションを非表示
  if (knowledgeSection) {
    knowledgeSection.style.display = 'none';
  }
  if (choiceButtons) {
    choiceButtons.style.display = 'none';
  }
}

// バックグラウンドで質問をロードして更新
async function loadQuestionsInBackground() {
  // まずデフォルト質問を設定（フォールバック）
  currentQuestions = createDefaultQuestions();
  console.log('🔄 デフォルト質問を設定:', currentQuestions.length + '件');
  
  try {
    console.log('🔄 バックグラウンドで質問データを取得中...');
    const spreadsheetQuestions = await getQuestionsFromSpreadsheet('第1段階', true);
    
    if (spreadsheetQuestions && spreadsheetQuestions.length > 0) {
      currentQuestions = convertSpreadsheetQuestions(spreadsheetQuestions);
      console.log('✅ スプレッドシート連携成功! 質問数:', currentQuestions.length);
      console.log('最初の質問:', currentQuestions[0]);
    } else {
      console.log('⚠️ スプレッドシートデータが空のため、デフォルト質問を使用');
    }
  } catch (error) {
    console.error('❌ スプレッドシート取得エラー:', error);
    console.log('⚠️ デフォルト質問を続行使用');
  }
  
  // インデックスをリセットして最初から開始
  currentQuestionIndex = 0;
  userAnswers = [];
  
  // 2秒後に正式な質問フローを開始
  setTimeout(() => {
    showQuestion(0);
  }, 2000);
}

