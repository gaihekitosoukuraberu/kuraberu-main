/**
 * 4段階ヒアリングチャットボットシステム
 * estimate-app専用
 */

// グローバル変数
let chatbotVisible = false;
let chatbotInitialized = false;
let currentStage = '第1段階';
let currentQuestions = [];
let stageAnswers = [];
let currentQuestionIndex = 0;
let userAnswers = [];
let chatHistory = [];
let isGPTResponding = false;
let questionPool = [];
let collectedData = {
  基本情報: {},
  現状診断: {},
  ご要望: {},
  お客様情報: {}
};

// GPTストリーミング対話関数
async function sendGPTMessage(userMessage, onTokenReceived) {
  try {
    const gasUrl = 'https://script.google.com/macros/s/AKfycbwZwxFeAimcpQ2FtAO02Sy83yRoyxeBcItJcl2R1-66gaNIrBtZ-lEu5CMPIKxWSZAv/exec';
    
    // メッセージ履歴に追加
    chatHistory.push({ role: 'user', content: userMessage });
    
    // システムプロンプトを作成
    const systemPrompt = createSalesPrompt(currentStage, collectedData, questionPool);
    
    const requestBody = {
      action: 'gptChat',
      systemPrompt: systemPrompt,
      messages: chatHistory,
      currentStage: currentStage,
      collectedData: collectedData,
      questionPool: questionPool,
      userMessage: userMessage
    };
    
    console.log('🤖 GPTに送信:', userMessage);
    console.log('📝 現在のステージ:', currentStage);
    console.log('📊 収集データ:', collectedData);
    
    const response = await fetch(gasUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      mode: 'cors',
      body: JSON.stringify(requestBody)
    });
    
    const result = await response.json();
    
    if (result.success && result.response) {
      // GPTのレスポンスを履歴に追加
      chatHistory.push({ role: 'assistant', content: result.response });
      
      // ストリーミングで表示（文字ごとに遅延）
      await simulateTyping(result.response, onTokenReceived);
      
      // 質問が含まれているかチェック
      if (result.hasQuestion && result.questionOptions) {
        return {
          response: result.response,
          hasQuestion: true,
          questionOptions: result.questionOptions,
          nextStage: result.nextStage || currentStage,
          dataToCollect: result.dataToCollect
        };
      }
      
      return {
        response: result.response,
        hasQuestion: false,
        nextStage: result.nextStage || currentStage
      };
    } else {
      throw new Error(result.error || 'GPT APIエラー');
    }
  } catch (error) {
    console.error('😱 GPT APIエラー:', error);
    return { success: false, error: error.toString() };
  }
}

// タイピングアニメーションシミュレーション
async function simulateTyping(text, onTokenReceived) {
  const words = text.split('');
  let currentText = '';
  
  for (let i = 0; i < words.length; i++) {
    currentText += words[i];
    onTokenReceived(currentText);
    
    // 日本語の場合は少し遅めに
    const delay = /[\u3040-\u309F\u30A0-\u30FF\u4E00-\u9FAF]/.test(words[i]) ? 30 : 20;
    await new Promise(resolve => setTimeout(resolve, delay));
  }
}

// GAS API呼び出し関数（既存機能用）
async function callGASAPI(action, parameters = {}) {
  try {
    const gasUrl = 'https://script.google.com/macros/s/AKfycbwZwxFeAimcpQ2FtAO02Sy83yRoyxeBcItJcl2R1-66gaNIrBtZ-lEu5CMPIKxWSZAv/exec';
    
    const requestBody = {
      action: action,
      ...parameters
    };
    
    console.log('GAS API呼び出し:', action, parameters);
    
    const response = await fetch(gasUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      mode: 'cors',
      body: JSON.stringify(requestBody)
    });
    
    const result = await response.json();
    console.log('GAS APIレスポンス:', result);
    
    return result;
  } catch (error) {
    console.error('GAS API呼び出しエラー:', error);
    console.log('⚠️ API失敗 - デフォルトデータを使用');
    return { success: false, error: error.toString() };
  }
}

// 新しい3層プロンプトシステム用のGPTメッセージ送信
async function sendGPTMessageNew(userMessage, currentStage, questionId, onTokenReceived) {
  try {
    const gasUrl = 'https://script.google.com/macros/s/AKfycbwZwxFeAimcpQ2FtAO02Sy83yRoyxeBcItJcl2R1-66gaNIrBtZ-lEu5CMPIKxWSZAv/exec';
    
    console.log('🤖 新GPTシステム送信:', userMessage);
    console.log('📝 段階:', currentStage, '質問ID:', questionId);
    
    const requestBody = {
      action: 'gptWithPromptLayers',
      currentStage: currentStage,
      questionId: questionId,
      userMessage: userMessage,
      collectedData: collectedData,
      userHistory: chatHistory.slice(-5) // 最新5件の履歴
    };
    
    const response = await fetch(gasUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      mode: 'cors',
      body: JSON.stringify(requestBody)
    });
    
    const result = await response.json();
    
    if (result.success) {
      // タイピングアニメーション
      await simulateTyping(result.response, onTokenReceived);
      
      return {
        success: true,
        response: result.response,
        hasQuestion: result.hasQuestion || true,
        questionOptions: result.questionOptions || generateSmartQuestionOptions(currentStage, userMessage),
        nextStage: result.nextStage || currentStage,
        dataToCollect: result.dataToCollect
      };
    } else {
      throw new Error(result.error || 'GPT処理エラー');
    }
    
  } catch (error) {
    console.error('😱 新GPTシステムエラー:', error);
    
    // フォールバック処理
    const fallbackResponse = generateFallbackResponse(currentStage, userMessage);
    await simulateTyping(fallbackResponse.response, onTokenReceived);
    
    return fallbackResponse;
  }
}

// 段階に応じたスマートな選択肢生成
function generateSmartQuestionOptions(currentStage, userMessage) {
  const smartOptions = {
    '第1段階': {
      '材質': ['サイディング（最も一般的）', 'モルタル（塗り壁）', 'ALC（軽量コンクリート）', 'タイル・その他'],
      '面積': ['100㎡未満（80-120万円目安）', '100-150㎡（100-160万円目安）', '150-200㎡（140-220万円目安）', '200㎡以上（180万円以上）'],
      '築年数': ['10年未満（メンテナンス期）', '10-15年（塗装推奨時期）', '15-20年（要注意時期）', '20年以上（緊急対応必要）']
    },
    '第2段階': {
      '外壁状態': ['チョーキング・色あせ（軽度劣化）', 'ひび割れ・剥がれ（中度劣化）', 'カビ・藻・汚れ（清掃+塗装必要）', '特に問題なし（予防メンテナンス）'],
      '屋根状態': ['色あせ・軽微な劣化', '錆・腐食が見られる', '瓦のズレ・割れあり', '特に問題なし']
    },
    '第3段階': {
      '工事時期': ['できるだけ早く（緊急性重視）', '3ヶ月以内（標準的）', '6ヶ月以内（計画的）', '1年以内（余裕をもって）'],
      '予算感': ['100万円未満（コスト重視）', '100-150万円（標準プラン）', '150-200万円（高品質プラン）', '200万円以上（最高級プラン）']
    },
    '第4段階': {
      '年代': ['30代（将来性重視）', '40代（実用性重視）', '50代（品質重視）', '60代以上（安心・信頼重視）'],
      '家族構成': ['夫婦のみ（シンプル重視）', '子育て世帯（安全性重視）', '三世代同居（全員の満足重視）', 'その他']
    }
  };
  
  // キーワードマッチングで適切な選択肢を選択
  for (const category in smartOptions[currentStage] || {}) {
    if (userMessage.includes(category) || category.includes('材質') && userMessage.includes('外壁')) {
      return smartOptions[currentStage][category];
    }
  }
  
  // デフォルト選択肢
  return Object.values(smartOptions[currentStage] || {})[0] || [
    'はい、教えてください',
    'もう少し詳しく',
    '他の選択肢は？',
    '後で決めます'
  ];
}

// フォールバック応答生成
function generateFallbackResponse(currentStage, userMessage) {
  const fallbackResponses = {
    '第1段階': {
      response: 'お住まいの基本情報を教えてください。外壁材質、面積、築年数から最適な業者と見積もりをご提案いたします。15年の経験をもとに、確実にお役に立てる情報をお伝えします。',
      questionOptions: ['サイディング（最も一般的）', 'モルタル（塗り壁）', 'ALC（軽量コンクリート）', 'タイル・その他']
    },
    '第2段階': {
      response: '現在の外壁の状態を確認させてください。劣化の程度により工事内容と費用が変わります。正確な診断で最適なプランをご提案いたします。',
      questionOptions: ['チョーキング・色あせ', 'ひび割れ・剥がれ', 'カビ・藻・汚れ', '特に問題なし']
    },
    '第3段階': {
      response: 'ご希望の工事時期と予算について教えてください。時期や予算に応じて3-4社の優良業者から最適なプランをご提案いたします。',
      questionOptions: ['できるだけ早く', '3ヶ月以内', '6ヶ月以内', '1年以内']
    },
    '第4段階': {
      response: 'お客様の年代や家族構成を教えてください。ライフステージに最適化した塗装プランと信頼できる業者をご紹介いたします。',
      questionOptions: ['30代', '40代', '50代', '60代以上']
    }
  };
  
  return {
    success: true,
    response: fallbackResponses[currentStage]?.response || '外壁塗装について詳しくお聞かせください。',
    hasQuestion: true,
    questionOptions: fallbackResponses[currentStage]?.questionOptions || ['はい', 'いいえ', 'わからない', '後で'],
    nextStage: currentStage,
    dataToCollect: null
  };
}

// 旧プロンプト生成システム（互換性のため残存）
function createSalesPrompt(currentStage, collectedData, questionPool) {
  // 新システムに移行済み - buildCompletePromptを使用
  console.log('⚠️ 旧プロンプトシステム呼び出し - 新システムに移行してください');
  
  return `外壁塗装の専門アドバイザーとして、${currentStage}での適切な営業対応を行ってください。
  
【基本方針】
- 15年の業界経験に基づく信頼できるアドバイス
- 3-4社の優良業者推薦
- お客様の立場に立った提案

【収集済みデータ】
${JSON.stringify(collectedData, null, 2)}

4択の選択肢を必ず提示し、JSON形式で回答してください。`;
}

// スプレッドシートから学習データを取得
function getLearningDataFromSpreadsheet() {
  // まずはキャッシュからチェック
  if (window.learningDataCache && Date.now() - window.learningDataCache.timestamp < 300000) { // 5分キャッシュ
    return window.learningDataCache.data;
  }
  
  // 非同期でスプレッドシートから取得
  loadLearningDataAsync();
  
  // キャッシュがない場合はデフォルト値
  return {
    salesStrategies: '信頼関係構築 → 専門診断 → 緊急性認識 → 価値提案 → 自然なクロージング',
    responsePatterns: '価格懸念: 品質と安全性の価値を強調、時期懸念: 最適タイミングの重要性説明',
    trustBuilding: '業界15年の経験と具体的な事例を交えた専門アドバイス',
    urgencyCreation: '放置による構造への影響を具体的数字で説明（築年数×劣化速度）',
    priceHandling: '3パターン見積もりで選択肢提示、長期的コストパフォーマンス重視',
    closingTechniques: '段階的合意形成、お客様のペースに合わせた決断サポート'
  };
}

// 学習データを非同期で読み込み
async function loadLearningDataAsync() {
  try {
    console.log('📚 ロープレ学習データ読み込み開始');
    
    const [salesData, responseData, scriptData] = await Promise.all([
      callGASAPI('getLearningData', { type: 'salesStrategies' }),
      callGASAPI('getLearningData', { type: 'responsePatterns' }),
      callGASAPI('getLearningData', { type: 'salesScripts' })
    ]);
    
    const learningData = {
      salesStrategies: salesData.success ? salesData.data : 'デフォルト戦略',
      responsePatterns: responseData.success ? responseData.data : 'デフォルト対応',
      trustBuilding: extractTrustBuildingData(salesData.data),
      urgencyCreation: extractUrgencyData(responseData.data),
      priceHandling: extractPriceHandlingData(scriptData.data),
      closingTechniques: extractClosingData(salesData.data)
    };
    
    // キャッシュに保存
    window.learningDataCache = {
      data: learningData,
      timestamp: Date.now()
    };
    
    console.log('✅ ロープレ学習データ読み込み完了');
    return learningData;
    
  } catch (error) {
    console.error('❌ 学習データ読み込みエラー:', error);
    return getLearningDataFromSpreadsheet(); // デフォルト値を返す
  }
}

// 学習データから特定要素を抽出
function extractTrustBuildingData(data) {
  if (!data || !Array.isArray(data)) return '専門知識による信頼関係構築';
  const trustData = data.filter(item => item.カテゴリ === '信頼構築');
  return trustData.map(item => item.台本内容).join('。') || '専門知識による信頼関係構築';
}

function extractUrgencyData(data) {
  if (!data || !Array.isArray(data)) return '劣化進行の具体的リスク説明';
  const urgencyData = data.filter(item => item.カテゴリ === '緊急性演出');
  return urgencyData.map(item => item.最適回答).join('。') || '劣化進行の具体的リスク説明';
}

function extractPriceHandlingData(data) {
  if (!data || !Array.isArray(data)) return '3パターン見積もりでの価値説明';
  const priceData = data.filter(item => item.カテゴリ === '価格対応');
  return priceData.map(item => item.台本内容).join('。') || '3パターン見積もりでの価値説明';
}

function extractClosingData(data) {
  if (!data || !Array.isArray(data)) return '段階的合意形成による自然なクロージング';
  const closingData = data.filter(item => item.カテゴリ === 'クロージング');
  return closingData.map(item => item.台本内容).join('。') || '段階的合意形成による自然なクロージング';
}

