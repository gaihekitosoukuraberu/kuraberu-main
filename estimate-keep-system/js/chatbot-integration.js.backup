/**
 * 📂 ファイル名: chatbot-integration.js
 * 🎯 内容: JSONファイル参照型AI風チャットシステム
 * 
 * 【責務】
 * - 郵便番号入力後のランキングカード（モザイク状態）表示
 * - JSONファイルから質問データ取得
 * - タイプライター演出で段階的質問表示
 * - 第1ヒアリング段階終了時にモザイク解除
 * - GPT API不使用（将来的に追加可能性あり）
 */

// ===========================================
// グローバル変数
// ===========================================

let questionsData = [];           // JSONファイルから取得した質問データ
let currentQuestionIndex = 0;     // 現在の質問インデックス
let userAnswers = [];            // ユーザーの回答履歴
let questionsCompleted = 0;      // 完了した質問数
let questionsDataCached = false; // キャッシュフラグ
let isTyping = false;            // タイプライター演出中フラグ
let chatbotVisible = false;      // チャットボット表示状態
let questionAnswered = false;    // 現在の質問に回答済みかのフラグ

// 設定値（動的に計算される）
let FIRST_STAGE_COMPLETION_THRESHOLD = 3; // 第1段階完了の閾値（物件規模ヒアリング）
let SECOND_STAGE_COMPLETION_THRESHOLD = 6; // 第2段階完了の閾値（詳細条件ヒアリング）
let THIRD_STAGE_COMPLETION_THRESHOLD = 9; // 第3段階完了の閾値（クロージングセクション）
let FOURTH_STAGE_COMPLETION_THRESHOLD = 10; // 第4段階完了の閾値（電話番号入力）

// GASエンドポイントURL（郵便番号検索のみ使用）
const SPREADSHEET_GAS_URL = 'https://script.google.com/macros/s/AKfycbz9BA4rQd3YDveOslmbO2deM5n_LySrVxxhrocvWUvAq3sb8wQQ-vfab5HHs3J0sqk1Hw/exec';

// 郵便番号検索API
async function searchPostalCode(postalCode) {
  try {
    console.log('🔍 郵便番号検索:', postalCode);
    
    const response = await fetch(`${SPREADSHEET_GAS_URL}?action=getAddressByPostalCode&postalCode=${encodeURIComponent(postalCode)}`);
    const result = await response.json();
    
    if (result.success) {
      console.log('✅ 郵便番号検索成功:', result);
      return {
        success: true,
        address: `${result.prefecture}${result.city}`
      };
    } else {
      console.log('❌ 郵便番号が見つかりません:', result.error);
      return {
        success: false,
        message: '該当する住所が見つかりませんでした'
      };
    }
  } catch (error) {
    console.error('❌ 郵便番号検索エラー:', error);
    return {
      success: false,
      message: 'サーバーエラーが発生しました'
    };
  }
}

// ===========================================
// JSONファイルからの質問データ取得
// ===========================================

/**
 * JSONファイルから質問データを取得
 */
async function loadQuestionsFromSpreadsheet() {
  try {
    // キャッシュされたデータがある場合はそれを使用
    if (questionsDataCached && questionsData.length > 0) {
      console.log('⚡ キャッシュされた質問データを使用');
      return true;
    }
    
    console.log('📋 JSONファイルから質問データを取得中...');
    
    // JSONファイルから質問データを読み込み
    const response = await fetch('./questions-data.json');
    const jsonData = await response.json();
    
    // JSON形式のデータを配列形式に変換
    questionsData = Object.entries(jsonData).map(([key, value]) => ({
      id: key,
      ...value
    }));
    
    console.log('✅ JSONファイルから質問データを取得:', questionsData.length, '件');
    questionsDataCached = true;
    return true;
    
  } catch (error) {
    console.error('❌ JSON質問取得エラー:', error);
    return false;
  }
}

// GPTチャットボットの自動起動
async function launchGPTChatbot() {
  try {
    console.log('🤖 GPTチャットボット起動開始');
    
    // 質問データの読み込み
    const loadSuccess = await loadQuestionsFromSpreadsheet();
    if (!loadSuccess) {
      console.error('❌ 質問データの読み込みに失敗');
      return;
    }
    
    // チャットボットを表示
    const chatbotContainer = document.getElementById('chatbotContainer');
    if (chatbotContainer) {
      chatbotContainer.classList.remove('translate-y-full');
      chatbotVisible = true;
      
      // 最初の質問を表示
      await displayQuestion(0);
    }
    
  } catch (error) {
    console.error('❌ GPTチャットボット起動エラー:', error);
  }
}

// 質問表示関数
async function displayQuestion(questionIndex) {
  if (questionIndex >= questionsData.length) {
    console.log('✅ 全質問完了');
    return;
  }
  
  const question = questionsData[questionIndex];
  console.log('🎯 質問表示:', question);
  
  // 質問をチャットに追加
  addMessageToChat(question.text, 'ai');
  
  // 選択肢ボタンを追加
  if (question.choices && question.choices.length > 0) {
    addChoiceButtons(question.choices, questionIndex);
  }
}

// チャットにメッセージを追加
function addMessageToChat(message, sender) {
  const chatMessages = document.getElementById('chatMessages');
  if (!chatMessages) return;
  
  const messageDiv = document.createElement('div');
  messageDiv.className = `ai-message-container new-message`;
  
  messageDiv.innerHTML = `
    <img src="https://cdn.jsdelivr.net/gh/microsoft/fluentui-emoji@main/assets/Robot/Flat/robot_flat.svg" alt="AI" class="ai-avatar">
    <div class="ai-message">${message}</div>
  `;
  
  chatMessages.appendChild(messageDiv);
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

// 選択肢ボタンを追加
function addChoiceButtons(choices, questionIndex) {
  const chatMessages = document.getElementById('chatMessages');
  if (!chatMessages) return;
  
  const buttonsDiv = document.createElement('div');
  buttonsDiv.className = 'choice-buttons';
  
  choices.forEach((choice, index) => {
    const button = document.createElement('button');
    button.textContent = choice;
    button.className = 'choice-button';
    button.onclick = () => handleChoiceClick(choice, questionIndex, index);
    buttonsDiv.appendChild(button);
  });
  
  chatMessages.appendChild(buttonsDiv);
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

// 選択肢クリック処理
async function handleChoiceClick(choice, questionIndex, choiceIndex) {
  console.log('👆 選択肢クリック:', choice, questionIndex, choiceIndex);
  
  // ユーザーの回答を記録
  userAnswers.push({
    questionId: questionsData[questionIndex].id,
    choice: choice,
    choiceIndex: choiceIndex
  });
  
  // ユーザーメッセージを表示
  addUserMessage(choice);
  
  // 選択肢ボタンを削除
  const choiceButtons = document.querySelectorAll('.choice-buttons');
  choiceButtons.forEach(btn => btn.remove());
  
  // 次の質問を決定
  const currentQuestion = questionsData[questionIndex];
  let nextQuestionId = null;
  
  if (currentQuestion.branches && currentQuestion.branches[choiceIndex]) {
    nextQuestionId = currentQuestion.branches[choiceIndex];
  }
  
  // 次の質問を表示
  if (nextQuestionId) {
    const nextQuestionIndex = questionsData.findIndex(q => q.id === nextQuestionId);
    if (nextQuestionIndex >= 0) {
      setTimeout(() => displayQuestion(nextQuestionIndex), 1000);
    }
  } else {
    console.log('✅ 質問完了');
  }
}

// ユーザーメッセージを追加
function addUserMessage(message) {
  const chatMessages = document.getElementById('chatMessages');
  if (!chatMessages) return;
  
  const messageDiv = document.createElement('div');
  messageDiv.className = 'user-message';
  messageDiv.textContent = message;
  
  chatMessages.appendChild(messageDiv);
  chatMessages.scrollTop = chatMessages.scrollHeight;
}

// グローバル関数として公開
window.launchGPTChatbot = launchGPTChatbot;
window.searchPostalCode = searchPostalCode;// File timestamp: 2025年 7月15日 火曜日 17時00分04秒 JST
